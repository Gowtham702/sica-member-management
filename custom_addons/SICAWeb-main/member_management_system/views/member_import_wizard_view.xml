<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Full Page Form View — No Popup -->
        <record id="view_member_import_wizard_form" model="ir.ui.view">
            <field name="name">member.import.wizard.form</field>
            <field name="model">member.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Import Members - Paid Till">
                    <sheet>

                        <div class="oe_title">
                            <h1>Import Members Paid Till</h1>
                            <p class="text-muted">
                                Upload your Excel file. Column A = Membership No. | Column B = Paid Till
                            </p>
                        </div>

                        <!-- Upload Section -->
                        <group attrs="{'invisible': [('state', '=', 'done')]}">
                            <group string="Upload Excel File">
                                <field name="excel_file" widget="binary" filename="file_name"/>
                                <field name="file_name" invisible="1"/>
                            </group>
                        </group>

                        <!-- Result Summary -->
                        <group attrs="{'invisible': [('state', '=', 'draft')]}">
                            <group string="Import Summary">
                                <field name="total_records"/>
                                <field name="updated_count"/>
                                <field name="not_found_count"/>
                                <field name="error_count"/>
                            </group>
                        </group>

                        <!-- Result Message -->
                        <group attrs="{'invisible': [('state', '=', 'draft')]}">
                            <field name="result_message" widget="text" nolabel="1" readonly="1"
                                style="background:#f8f9fa; padding:15px; border-radius:5px; font-family:monospace; font-size:14px;"/>
                        </group>

                        <field name="state" invisible="1"/>

                    </sheet>

                    <!-- Buttons at top -->
                    <header>
                        <button name="action_import"
                                string="Import Now"
                                type="object"
                                class="btn-primary"
                                attrs="{'invisible': [('state', '=', 'done')]}"/>

                        <button name="action_reset"
                                string="Import Another File"
                                type="object"
                                class="btn-secondary"
                                attrs="{'invisible': [('state', '=', 'draft')]}"/>
                    </header>

                </form>
            </field>
        </record>

        <!-- Action — Opens as Full Page -->
        <record id="action_member_import_wizard" model="ir.actions.act_window">
            <field name="name">data fix imports</field>
            <field name="res_model">member.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
        </record>

    </data>
</odoo>