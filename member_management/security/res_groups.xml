<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Admin Group -->
        <record id="group_sica_admin" model="res.groups">
            <field name="name">SICA Admin</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Staff User Group -->
        <record id="group_sica_staff" model="res.groups">
            <field name="name">SICA Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
