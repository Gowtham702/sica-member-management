<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Member Form View -->
    <record id="view_sica_member_form" model="ir.ui.view">
        <field name="name">sica.member.form</field>
        <field name="model">sica.member</field>
        <field name="arch" type="xml">
            <form string="Member">
                <header>
                    <button name="action_print_member_report"
                        string="Print Report"
                        type="object"
                        class="btn-primary"/>
                    <field name="status" widget="statusbar"
                        statusbar_visible="active,expired"/>
                </header>
                <sheet>
                    <!-- Smart Button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_total_members"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-users">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Total Members</span>
                            </div>
                        </button>
                    </div>

                    <!-- Profile Photo -->
                    <field name="profile_photo" widget="image"
                        class="oe_avatar"
                        options="{'preview_image': 'profile_photo'}"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Member Name"/></h1>
                        <h4 class="text-muted">
                            <field name="member_id" readonly="1"/>
                        </h4>
                    </div>

                    <group>
                        <group string="Personal Information">
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="address"/>
                            <field name="company_name"/>
                            <field name="designation"/>
                        </group>
                        <group string="Membership Information">
                            <field name="membership_type_id"/>
                            <field name="joining_date"/>
                            <field name="expiry_date" readonly="1"/>
                            <field name="status" readonly="1"
                                widget="badge"
                                decoration-success="status == 'active'"
                                decoration-danger="status == 'expired'"/>
                        </group>
                    </group>

                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Member List View -->
    <record id="view_sica_member_tree" model="ir.ui.view">
        <field name="name">sica.member.tree</field>
        <field name="model">sica.member</field>
        <field name="arch" type="xml">
            <list string="Members" export_xlsx="1">
                <field name="member_id"/>
                <field name="name"/>
                <field name="mobile"/>
                <field name="membership_type_id"/>
                <field name="joining_date"/>
                <field name="expiry_date"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'active'"
                    decoration-danger="status == 'expired'"/>
            </list>
        </field>
    </record>

    <!-- Member Search View -->
    <record id="view_sica_member_search" model="ir.ui.view">
        <field name="name">sica.member.search</field>
        <field name="model">sica.member</field>
        <field name="arch" type="xml">
            <search string="Search Members">
                <field name="name" string="Member Name"/>
                <field name="member_id" string="Member ID"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="membership_type_id"/>
                <field name="company_name"/>

                <!-- Filters -->
                <filter string="Active Members" name="active_members"
                    domain="[('status','=','active')]"/>
                <filter string="Expired Members" name="expired_members"
                    domain="[('status','=','expired')]"/>
                <separator/>
                <filter string="Silver Members" name="silver"
                    domain="[('membership_type_id.name','=','Silver')]"/>
                <filter string="Gold Members" name="gold"
                    domain="[('membership_type_id.name','=','Gold')]"/>
                <filter string="Premium Members" name="premium"
                    domain="[('membership_type_id.name','=','Premium')]"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter string="Membership Type" name="group_membership"
                        context="{'group_by': 'membership_type_id'}"/>
                    <filter string="Status" name="group_status"
                        context="{'group_by': 'status'}"/>
                    <filter string="Joining Date" name="group_joining"
                        context="{'group_by': 'joining_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Member Action -->
    <record id="action_sica_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">sica.member</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sica_member_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first SICA Member!
            </p>
        </field>
    </record>
</odoo>
