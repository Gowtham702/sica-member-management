<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sica_member_form" model="ir.ui.view">
        <field name="name">sica.member.form</field>
        <field name="model">sica.member</field>
        <field name="arch" type="xml">
            <form string="Member">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="active,expired"/>
                </header>
                <sheet>
                    <field name="profile_photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Member Name"/></h1>
                        <h4><field name="member_id" readonly="1"/></h4>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="address"/>
                            <field name="company_name"/>
                            <field name="designation"/>
                        </group>
                        <group string="Membership Information">
                            <field name="membership_type_id"/>
                            <field name="joining_date"/>
                            <field name="expiry_date" readonly="1"/>
                            <field name="status" readonly="1" widget="badge"
                                decoration-success="status == 'active'"
                                decoration-danger="status == 'expired'"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sica_member_tree" model="ir.ui.view">
        <field name="name">sica.member.tree</field>
        <field name="model">sica.member</field>
        <field name="arch" type="xml">
            <list string="Members">
                <field name="member_id"/>
                <field name="name"/>
                <field name="mobile"/>
                <field name="membership_type_id"/>
                <field name="joining_date"/>
                <field name="expiry_date"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'active'"
                    decoration-danger="status == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="action_sica_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">sica.member</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first SICA Member!</p>
        </field>
    </record>
</odoo>